---
import '../styles/global.css';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Production-Style Kubernetes Platform',
  description = 'Building cloud-native infrastructure with Kubernetes, Terraform, GitOps and Observability.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script defer src="https://umami.rubenspensky.com/script.js" data-website-id="9dc0a66a-d7ea-43f7-94dc-e9b514054830"></script>
    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
