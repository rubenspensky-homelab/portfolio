---
import OperatorStrip from '@/components/OperatorStrip.astro';

const meta = [
  ['owner', 'ruben velazquez flores'],
  ['maintainer', 'solo operator'],
  ['project type', 'personal platform'],
  ['environment', 'homelab'],
  ['control plane', 'kubernetes'],
  ['deployment', 'gitops'],
  ['status', 'operational']
];
---

<section class="hero shell">
  <div class="hero-main">
    <OperatorStrip />
    <p class="eyebrow">public platform engineering console</p>
    <h1>Production-Style Kubernetes Platform</h1>
    <p class="subtitle">Building cloud-native infrastructure with Kubernetes, Terraform, GitOps and Observability.</p>
    <p class="intro">
      A personal platform engineering project built to demonstrate how a Kubernetes-based internal developer platform
      can be designed, automated, operated and observed in public.
    </p>
    <div class="button-row">
      <a class="button" href="#platform">Explore Platform</a>
      <a class="button secondary" href="https://github.com/rubenspensky-homelab" target="_blank" rel="noreferrer">View GitHub</a>
    </div>
  </div>
  <aside class="hero-console panel" aria-label="Platform metadata">
    <div class="console-head">
      <span>platformctl inspect</span>
      <span>readonly</span>
    </div>
    <div class="console-body">
      {meta.map(([key, value]) => (
        <div class="console-row">
          <span>{key}</span>
          <strong>{value}</strong>
        </div>
      ))}
    </div>
    <pre>reconcile: continuous
exposure: cloudflare edge
telemetry: metrics/logs/traces</pre>
  </aside>
</section>

<style>
  .hero {
    display: grid;
    min-height: calc(100vh - 64px);
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
    gap: 34px;
    align-items: center;
    padding: 72px 0;
  }

  h1 {
    max-width: 880px;
    margin: 12px 0 18px;
    font-size: clamp(50px, 9vw, 112px);
    line-height: 0.88;
    letter-spacing: -0.09em;
    text-transform: uppercase;
  }

  .subtitle {
    max-width: 720px;
    margin: 0 0 16px;
    color: var(--muted);
    font-size: clamp(17px, 2vw, 22px);
  }

  .intro {
    max-width: 760px;
    margin: 0 0 28px;
    border-left: 1px solid var(--border-strong);
    padding-left: 16px;
    color: var(--muted);
    font-size: 14px;
  }

  .hero-console {
    align-self: stretch;
    min-height: 420px;
    display: flex;
    flex-direction: column;
  }

  .console-head {
    display: flex;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    padding: 12px;
    color: var(--dim);
    font-size: 11px;
    text-transform: uppercase;
  }

  .console-body {
    display: grid;
    gap: 1px;
    background: var(--border);
  }

  .console-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 16px;
    padding: 16px 14px;
    background: var(--surface);
  }

  .console-row span {
    color: var(--dim);
    text-transform: uppercase;
  }

  .console-row strong {
    color: var(--text);
    text-transform: uppercase;
  }

  pre {
    flex: 1;
    margin: 0;
    border-top: 1px solid var(--border);
    padding: 16px 14px;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 12px;
    white-space: pre-wrap;
  }

  @media (max-width: 860px) {
    .hero {
      min-height: auto;
      grid-template-columns: 1fr;
      padding: 48px 0;
    }

    .hero-console {
      min-height: auto;
    }
  }
</style>
