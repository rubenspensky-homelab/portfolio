---
import { navItems } from '@/data/platform';
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label="Home">
      <span class="brand-mark">HP</span>
      <span>
        <strong>Homelab Platform</strong>
        <small>public control plane</small>
      </span>
    </a>
    <nav aria-label="Main navigation">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <a class="header-status" href="https://github.com/rubenspensky-homelab/homelab-infra" target="_blank" rel="noreferrer">
      <span class="status-dot"></span>Status: Operational
    </a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    border-bottom: 1px solid var(--border);
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(10px);
  }

  .header-inner {
    display: grid;
    min-height: 64px;
    grid-template-columns: auto 1fr auto;
    gap: 22px;
    align-items: center;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .brand-mark {
    display: inline-grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid var(--border-strong);
    background: var(--text);
    color: var(--bg);
    font-size: 12px;
    font-weight: 800;
  }

  .brand strong,
  .brand small {
    display: block;
  }

  .brand strong {
    font-size: 13px;
    line-height: 1.1;
  }

  .brand small {
    color: var(--dim);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  nav {
    display: flex;
    justify-content: center;
    gap: 2px;
  }

  nav a,
  .header-status {
    border: 1px solid transparent;
    padding: 8px 10px;
    color: var(--muted);
    font-size: 12px;
    text-transform: uppercase;
  }

  nav a:hover,
  .header-status:hover {
    border-color: var(--border);
    color: var(--text);
  }

  .header-status {
    white-space: nowrap;
  }

  @media (max-width: 940px) {
    .header-inner {
      grid-template-columns: 1fr auto;
      padding: 12px 0;
    }

    nav {
      grid-column: 1 / -1;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 4px;
    }
  }

  @media (max-width: 560px) {
    .header-status {
      display: none;
    }
  }
</style>
