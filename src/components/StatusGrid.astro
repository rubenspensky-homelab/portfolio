---
import { platformOverview } from '@/data/platform';
---

<section class="section" id="overview">
  <div class="shell">
    <div class="section-header">
      <div>
        <p class="eyebrow">live platform overview</p>
        <h2 class="section-title">Runtime Surface</h2>
      </div>
      <p class="section-copy">
        Mocked operational data presented as the future public read-only view of the platform. The layout is designed
        to accept live signals from Kubernetes, GitOps and observability systems later.
      </p>
    </div>
    <div class="status-grid">
      {platformOverview.map((card) => (
        <article class="status-card panel">
          <header>
            <span class="terminal-label">{card.title}</span>
            <strong><span class="status-dot"></span>{card.status}</strong>
          </header>
          <dl>
            {card.rows.map(([key, value]) => (
              <div>
                <dt>{key}</dt>
                <dd>{value}</dd>
              </div>
            ))}
          </dl>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .status-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    border: 1px solid var(--border);
    background: var(--border);
  }

  .status-card {
    border: 0;
    min-height: 210px;
    padding: 16px;
  }

  header {
    display: flex;
    min-height: 58px;
    flex-direction: column;
    justify-content: space-between;
    gap: 12px;
  }

  header strong {
    color: var(--text);
    font-size: 12px;
    text-transform: uppercase;
  }

  dl {
    margin: 20px 0 0;
  }

  dl div {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    border-top: 1px solid var(--border);
    padding: 9px 0;
  }

  dt,
  dd {
    margin: 0;
    font-size: 12px;
    text-transform: uppercase;
  }

  dt {
    color: var(--dim);
  }

  dd {
    color: var(--muted);
    text-align: right;
  }

  @media (max-width: 980px) {
    .status-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .status-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
