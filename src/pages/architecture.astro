---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArchitectureFlow from '@/components/ArchitectureFlow.astro';
---

<BaseLayout title="Architecture | Homelab Platform Control Plane">
  <section class="section page-hero">
    <div class="shell">
      <p class="eyebrow">/architecture</p>
      <h1>System Architecture</h1>
      <p>Source-controlled delivery path from developer workflow to Kubernetes workloads and telemetry backends.</p>
    </div>
  </section>
  <ArchitectureFlow />
</BaseLayout>

<style>
  .page-hero {
    border-top: 0;
    padding-top: 72px;
  }

  h1 {
    margin: 10px 0 16px;
    font-size: clamp(42px, 8vw, 96px);
    line-height: 0.9;
    letter-spacing: -0.09em;
    text-transform: uppercase;
  }

  p:not(.eyebrow) {
    max-width: 760px;
    color: var(--muted);
  }
</style>
